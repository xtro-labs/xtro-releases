{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Xtro",
  "colors": {
    "primary": "#5C8600",
    "light": "#CCFF00",
    "dark": "#5C8600"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "anchors": [
      {
        "anchor": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "introduction",
              "quick-start",
              "how-it-works"
            ]
          },
          {
            "group": "Self-Hosting",
            "pages": [
              "self-hosting/relay-server"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/xtro-labs",
          "icon": "github"
        }
      ]
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      {
        "title": "Share on X",
        "description": "Share this page on X",
        "icon": "x",
        "href": {
          "base": "https://x.com/intent/tweet",
          "query": [
            {
              "key": "text",
              "value": "Check out this documentation: $page"
            }
          ]
        }
      },
      {
        "title": "Share on Reddit",
        "description": "Share this page on Reddit",
        "icon": "reddit",
        "href": {
          "base": "https://reddit.com/submit",
          "query": [
            {
              "key": "url",
              "value": "$page"
            }
          ]
        }
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Download",
        "href": "https://xtro.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://xtro.dev"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/xtro-labs",
      "twitter": "https://twitter.com/xtrodev"
    }
  }
}
